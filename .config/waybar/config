{
  "layer": "top",
  "exclusive": true,
  "position": "top",
  "margin-top": 9,
  "width": 1450,
  "reload_style_on_change": true,

  "modules-center": [
    "hyprland/window",
    "custom/separator",
    "hyprland/workspaces",
    "custom/separator",
    "custom/mpris",
    "custom/separator",
    "clock",
    "custom/pomo",
    "pulseaudio",
    "backlight",
    "custom/memorypie",
    "battery",
    "tray"
  ],

  "hyprland/workspaces": {
    "format": "{icon}",
    "format-icons": {
      "active": "",
      "default": "",
      "empty": ""
    },
    "persistent-workspaces": {
      "*": [1, 2, 3, 4, 5]
    },
    "tooltip": false
  },

  "hyprland/window": {
    "format": "{class}",
    "rewrite": {
      "^$": "Desktop"
    },
    "max-length": 15,
    "min-length": 15,
    "separate-outputs": true,
    "tooltip": false
  },

  "custom/separator": {
    "format": "|",
    "tooltip": false
  },

  "custom/mpris": {
    "exec": "~/.config/waybar/scripts/mpris.sh",
    "interval": 2,
    "return-type": "json",
    "max-length": 25,
    "min-length": 25,
    "on-click": "playerctl play-pause",
    "tooltip": false
  },

  "clock": {
    "format": "{:%I:%M %p}",
    "format-alt": "{:%a, %d %b}",
    "tooltip": false
  },

  "pulseaudio": {
    "format": "{icon}  {volume}%",
    "format-muted": "󰝟",
    "format-icons": {
      "default": ["", "", ""]
    },
    "on-click": "pavucontrol",
    "tooltip": false
  },

  "backlight": {
    "format": "{icon}  {percent}%",
    "format-icons": ["󰃞", "󰃟", "󰃠"],
    "on-scroll-up": "brightnessctl -d amdgpu_bl1 -e4 -n2 set 5%+",
    "on-scroll-down": "brightnessctl -d amdgpu_bl1 -e4 -n2 set 5%-",
    "smooth-scrolling-threshold": 0.2,
    "tooltip": false
  },

  "custom/memorypie": {
    "exec": "~/.config/waybar/scripts/memory_pie.sh",
    "interval": 2,
    "return-type": "json",
    "tooltip": false
  },

  "battery": {
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "{icon} {capacity}%",
    "format-charging": " {capacity}%",
    "format-icons": ["󰂃", "󰁺", "󰁻", "󰁼", "󰁽", "󰁾", "󰁿", "󰂀", "󰂁", "󰂂"],
    "tooltip": false
  },

  "custom/pomo": {
    "exec": "~/.config/waybar/scripts/pomo.sh",
    "on-click": "~/.config/waybar/scripts/pomo.sh toggle",
    "interval": 1,
    "return-type": "json",
    "format": " {}",
    "tooltip": false
  },

  "tray": {
    "spacing": 8,
    "tooltip": false
  }
}
