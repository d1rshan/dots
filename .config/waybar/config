{
  "layer": "top",
  "exclusive": true,
  "position": "top",
  "margin-top": 9,
  "width": 1450,
  "reload_style_on_change": true,

  "modules-center": [
    "hyprland/window",
    "custom/separator",
    "hyprland/workspaces",
    "custom/separator",
    "mpris",
    "custom/separator",
    "clock",
    "custom/pomo",
    "pulseaudio",
    "custom/memorypie",
    "battery",
    "tray"
  ],

  "hyprland/workspaces": {
    "format": "{icon}",
    "format-icons": {
      "active": "",
      "default": "",
      "empty": ""
    },
    "persistent-workspaces": {
      "*": [1, 2, 3, 4, 5]
    }
  },

  "hyprland/window": {
    "format": "{class}",
    "rewrite": {
      "^$": "Desktop"
    },
    "max-length": 15,
    "min-length": 15,
    "separate-outputs": true,
    "tooltip": false
  },

  "custom/separator": {
    "format": "|",
    "tooltip": false
  },

  "mpris": {
    "format": "{player_icon} {title}",
    "format-paused": "⏸ {title}",
    "max-length": 25,
    "min-length": 25,
    "on-click": "playerctl play-pause",
    "player-icons": {
      "firefox": "",
      "zen": "",
      "chromium": "",
      "spotify": "",
      "vlc": "󰕼",
      "default": ""
    },
    "ignored-players": ["mpd"],
    "tooltip": true
  },

  "clock": {
    "format": "{:%I:%M %p}",
    "format-alt": "{:%a, %d %b}",
    "tooltip": false
  },

  "pulseaudio": {
    "format": "{icon}  {volume}%",
    "format-muted": "󰝟",
    "format-icons": {
      "default": ["", "", ""]
    },
    "on-click": "pavucontrol",
    "tooltip": false
  },

  "custom/memorypie": {
    "exec": "~/.config/waybar/scripts/memory_pie.sh",
    "interval": 2,
    "return-type": "json",
    "tooltip": true
  },

  "battery": {
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "{icon} {capacity}%",
    "format-charging": " {capacity}%",
    "format-icons": ["󰂃", "󰁺", "󰁻", "󰁼", "󰁽", "󰁾", "󰁿", "󰂀", "󰂁", "󰂂"],
    "tooltip": false
  },

  "custom/pomo": {
    "exec": "~/.config/waybar/scripts/pomo.sh",
    "on-click": "~/.config/waybar/scripts/pomo.sh toggle",
    "interval": 1,
    "return-type": "json",
    "format": " {}"
  },

  "tray": {
    "spacing": 8,
    "tooltip": false
  }
}
